# DASC Server Manager - config.env.example
#
# Este archivo es una plantilla.
# No debe copiarse a producción sin revisar.
#
# Sustituye los valores IP_SERVIDOR_* según el perfil:
#
# Lite:
# - API, DB y backups pueden estar en el mismo servidor.
# - Se permite 127.0.0.1 para servicios locales.
#
# PyME 2 servidores:
# - Servidor 1: API / panel / backups.
# - Servidor 2: DB / logs.
#
# Pro 3 servidores:
# - Servidor 1: API / panel.
# - Servidor 2: DB / logs.
# - Servidor 3: backups / almacenamiento.
#
# ==========================
# DASC Server Manager
# Archivo de ejemplo
# Copiar como config.env y modificar valores
# ==========================

SECRET_KEY=CAMBIAR_SECRET_KEY_SEGURA
ADMIN_USER=admin
ADMIN_PASSWORD=CAMBIAR_PASSWORD_ADMIN

SSH_USER=dasc
SERVICIOS_HOST=IP_SERVIDOR_SERVICIOS_O_BACKUPS
BACKUPS_HOST=IP_SERVIDOR_BACKUPS
TERMINAL_DATABASE_HOST=IP_SERVIDOR_DB

CACTI_URL=/cacti/

LOGS_DB_HOST=IP_SERVIDOR_DB
LOGS_DB_NAME=dasc_logs
LOGS_DB_USER=dasc_logs
LOGS_DB_PASS=dasc_logs_2026
LOGS_ORIGIN=dasc-web

ALERTS_DB_PATH=data/alerts.db
ALERTS_DEFAULT_CHANNEL=telegram

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHAT_ID=

# SSH endurecido DASC
DASC_SSH_KEY=/opt/dasc/api/.ssh/id_rsa_dasc
DASC_SSH_KNOWN_HOSTS=/opt/dasc/api/.ssh/known_hosts_dasc
DASC_SSH_TIMEOUT=30
DASC_SSH_CONNECT_TIMEOUT=10
DASC_SSH_STDIN_MAX_LENGTH=20000
DASC_SSH_ALLOWED_HOSTS=127.0.0.1,localhost,IP_SERVIDOR_DB,IP_SERVIDOR_BACKUPS,IP_SERVIDOR_SERVICIOS
# Backup remoto de base de datos
BACKUP_DB_HOST=IP_SERVIDOR_DB
BACKUP_DB_NAME=dasc_logs
BACKUP_DB_USER=dasc_backup
BACKUP_DB_PASS=CAMBIAR_PASSWORD_BACKUP
BACKUP_OUTPUT_DIR=/var/backups/dasc/mysql/full

BACKUP_RETENTION_KEEP=10

# Restauración controlada de backups
RESTORE_DB_HOST=IP_SERVIDOR_DB
RESTORE_DB_USER=dasc_restore
RESTORE_DB_PASS=CAMBIAR_PASSWORD_RESTORE
RESTORE_TARGET_DB=dasc_logs_restore_test

# Seguridad web (opcional)
# CORS: orígenes permitidos separados por comas. Vacío = solo mismo origen (recomendado).
DASC_CORS_ALLOWED_ORIGINS=
# Cookie de sesión solo por HTTPS. Activar (true) cuando el proxy sirva HTTPS real.
DASC_SESSION_HTTPS_ONLY=false
# Duración de la sesión en segundos (por defecto 28800 = 8 horas).
DASC_SESSION_MAX_AGE=28800
# Protección anti fuerza bruta en el login.
DASC_LOGIN_MAX_ATTEMPTS=5
DASC_LOGIN_WINDOW_SECONDS=900

# ── Notificaciones proactivas (Ruta 7.5) ──────────────────────────────────
# Activa las comprobaciones automáticas de disco, backup y servicios.
# El panel envía alertas por Telegram (si está configurado) y/o por email.
NOTIF_ENABLED=false

# Email de destino para alertas proactivas
NOTIF_EMAIL_TO=admin@tuempresa.com
NOTIF_EMAIL_FROM=dasc@tuempresa.com

# Servidor SMTP (ej: smtp.gmail.com con contraseña de aplicación)
NOTIF_SMTP_HOST=smtp.gmail.com
NOTIF_SMTP_PORT=587
NOTIF_SMTP_USER=dasc@tuempresa.com
NOTIF_SMTP_PASS=CONTRASEÑA_DE_APLICACION

# Porcentaje de disco a partir del cual se envía alerta (por defecto 80%)
NOTIF_DISK_THRESHOLD=80

# Segundos entre comprobaciones automáticas (por defecto 900 = 15 min)
NOTIF_CHECK_INTERVAL=900

# Segundos mínimos entre dos alertas del mismo tipo (por defecto 14400 = 4 h)
NOTIF_COOLDOWN=14400

# ── Integraciones externas (R-069 / Ruta 8.5) ────────────────────────────────
# URL webhook Jira Service Management (vacío = desactivado).
# Cuando se crea un ticket de soporte en el panel, se hace un POST a esta URL.
# Compatible con cualquier webhook que acepte JSON (Jira, GitHub Issues, etc.)
# Ejemplo Jira: https://tu-instancia.atlassian.net/rest/webhooks/1.0/webhook/<ID>
JIRA_WEBHOOK_URL=

# Segundos de timeout para el webhook Jira (por defecto 5)
JIRA_WEBHOOK_TIMEOUT=5

# ── Heartbeat a Central Support (R-080 / Ruta 10.4)
# Intervalo en segundos entre heartbeats (por defecto 300 = 5 minutos).
# Requiere que CENTRAL_SUPPORT_ENABLED=true y CENTRAL_SUPPORT_URL configurados.
# Valor 0 desactiva el heartbeat aunque el soporte central esté activo.
CENTRAL_HEARTBEAT_INTERVAL=300
