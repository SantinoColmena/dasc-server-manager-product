# Vigex - config.env.example
#
# Este archivo es una plantilla.
# No debe copiarse a producción sin revisar.
#
# Sustituye los valores IP_SERVIDOR_* según el perfil:
#
# Lite:
# - API, DB y backups pueden estar en el mismo servidor.
# - Se permite 127.0.0.1 para servicios locales.
#
# PyME 2 servidores:
# - Servidor 1: API / panel / backups.
# - Servidor 2: DB / logs.
#
# Pro 3 servidores:
# - Servidor 1: API / panel.
# - Servidor 2: DB / logs.
# - Servidor 3: backups / almacenamiento.
#
# ==========================
# Vigex
# Archivo de ejemplo
# Copiar como config.env y modificar valores
# ==========================

SECRET_KEY=CAMBIAR_SECRET_KEY_SEGURA
ADMIN_USER=admin
ADMIN_PASSWORD=CAMBIAR_PASSWORD_ADMIN

SSH_USER=vigex
SERVICIOS_HOST=IP_SERVIDOR_SERVICIOS_O_BACKUPS
BACKUPS_HOST=IP_SERVIDOR_BACKUPS
TERMINAL_DATABASE_HOST=IP_SERVIDOR_DB

CACTI_URL=/cacti/

LOGS_DB_HOST=IP_SERVIDOR_DB
LOGS_DB_NAME=vigex_logs
LOGS_DB_USER=vigex_logs
LOGS_DB_PASS=vigex_logs_2026
LOGS_ORIGIN=vigex-web

ALERTS_DB_PATH=data/alerts.db
# Base de datos del módulo de cumplimiento NIS2/ENS/ISO 27001 (R-091 / Fase 13)
CUMPLIMIENTO_DB_PATH=data/cumplimiento.db
# Activa la recolección automática de evidencias (R-092). true por defecto.
CUMPLIMIENTO_ENABLED=true
# Segundos entre recolecciones automáticas (por defecto 86400 = 24 h).
CUMPLIMIENTO_COLLECT_INTERVAL=86400
ALERTS_DEFAULT_CHANNEL=telegram

# ── Alertas Telegram (R-098) ──────────────────────────────────────────────────
# Modo centralizado (recomendado): el cliente solo necesita su TELEGRAM_CHAT_ID.
# El bot @VigexPanelBot es gestionado por Vigex Central — sin crear bots propios.
#   "central" → usa @VigexPanelBot via Vigex Central (requiere CENTRAL_SUPPORT_URL)
#   "local"   → comportamiento clásico (requiere TELEGRAM_BOT_TOKEN propio)
VIGEX_TELEGRAM_MODE=central
# Chat ID del cliente en Telegram. Para obtenerlo: escribe /chatid al bot @VigexPanelBot.
TELEGRAM_CHAT_ID=
# Solo necesarios si VIGEX_TELEGRAM_MODE=local (bot propio):
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# SSH endurecido Vigex
VIGEX_SSH_KEY=/opt/vigex/api/.ssh/id_rsa_vigex
VIGEX_SSH_KNOWN_HOSTS=/opt/vigex/api/.ssh/known_hosts_vigex
VIGEX_SSH_TIMEOUT=30
VIGEX_SSH_CONNECT_TIMEOUT=10
VIGEX_SSH_STDIN_MAX_LENGTH=20000
VIGEX_SSH_ALLOWED_HOSTS=127.0.0.1,localhost,IP_SERVIDOR_DB,IP_SERVIDOR_BACKUPS,IP_SERVIDOR_SERVICIOS
# Multiplexación SSH: reutiliza la conexión entre llamadas seguidas al mismo host
# (acelera el dashboard y el monitoreo). true por defecto; degrada solo si falla.
VIGEX_SSH_MULTIPLEX=true
VIGEX_SSH_CONTROL_PERSIST=30
VIGEX_SSH_CONTROL_DIR=/opt/vigex/api/.ssh/cm
# Backup remoto de base de datos
BACKUP_DB_HOST=IP_SERVIDOR_DB
BACKUP_DB_NAME=vigex_logs
BACKUP_DB_USER=vigex_backup
BACKUP_DB_PASS=CAMBIAR_PASSWORD_BACKUP
BACKUP_OUTPUT_DIR=/var/backups/vigex/mysql/full

BACKUP_RETENTION_KEEP=10

# Restauración controlada de backups
RESTORE_DB_HOST=IP_SERVIDOR_DB
RESTORE_DB_USER=vigex_restore
RESTORE_DB_PASS=CAMBIAR_PASSWORD_RESTORE
RESTORE_TARGET_DB=vigex_logs_restore_test

# Seguridad web (opcional)
# CORS: orígenes permitidos separados por comas. Vacío = solo mismo origen (recomendado).
VIGEX_CORS_ALLOWED_ORIGINS=
# Cookie de sesión solo por HTTPS. Activar (true) cuando el proxy sirva HTTPS real.
VIGEX_SESSION_HTTPS_ONLY=false
# Duración de la sesión en segundos (por defecto 28800 = 8 horas).
VIGEX_SESSION_MAX_AGE=28800
# Auto-logout por inactividad en minutos (0 = desactivado). Configurable desde el panel.
VIGEX_AUTO_LOGOUT_MINUTES=60

# ── Asistente IA / RAG (R-090 / R-097) ────────────────────────────────────
# Activa el asistente IA del panel. false = sección oculta en el menú.
VIGEX_RAG_ENABLED=true
# Proveedor LLM:
#   "central"   → proxy Vigex Central (recomendado en producción; sin API key en el cliente)
#   "ollama"    → Ollama local (sin coste, requiere Ollama instalado)
#   "anthropic" | "gemini" | "openai" | "groq" → API directa (requiere clave propia)
# Con "central" el cliente solo necesita CENTRAL_SUPPORT_URL y CENTRAL_SUPPORT_TOKEN.
VIGEX_RAG_LLM_PROVIDER=central
# URL base de Ollama (solo si VIGEX_RAG_LLM_PROVIDER=ollama).
VIGEX_RAG_OLLAMA_URL=http://localhost:11434
# Modelo Ollama a usar. Descárgalo con: ollama pull mistral
VIGEX_RAG_OLLAMA_MODEL=mistral
# Claves de API directas (solo rellenar si NO usas "central" como proveedor).
ANTHROPIC_API_KEY=
VIGEX_RAG_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GOOGLE_API_KEY=
VIGEX_RAG_GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
VIGEX_RAG_OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
VIGEX_RAG_GROQ_MODEL=llama-3.3-70b-versatile
# Número de entradas FAQ a incluir como contexto en cada respuesta.
VIGEX_RAG_TOP_K=5
# Tokens máximos en la respuesta generada.
VIGEX_RAG_MAX_TOKENS=700
# Rate limiting del Asistente IA: máximo de mensajes por usuario en la ventana deslizante.
# Evita que un usuario abuse de la API y consuma toda la cuota. (R-090-sec)
VIGEX_RAG_RATE_LIMIT_REQS=30
VIGEX_RAG_RATE_LIMIT_WINDOW=60

# Protección anti fuerza bruta en el login.
VIGEX_LOGIN_MAX_ATTEMPTS=5
VIGEX_LOGIN_WINDOW_SECONDS=900

# ── Notificaciones proactivas (Ruta 7.5) ──────────────────────────────────
# Activa las comprobaciones automáticas de disco, backup y servicios.
# El panel envía alertas por Telegram (si está configurado) y/o por email.
NOTIF_ENABLED=false

# Email de destino para alertas proactivas
NOTIF_EMAIL_TO=admin@tuempresa.com
NOTIF_EMAIL_FROM=vigex@tuempresa.com

# Servidor SMTP (ej: smtp.gmail.com con contraseña de aplicación)
NOTIF_SMTP_HOST=smtp.gmail.com
NOTIF_SMTP_PORT=587
NOTIF_SMTP_USER=vigex@tuempresa.com
NOTIF_SMTP_PASS=CONTRASEÑA_DE_APLICACION

# Porcentaje de disco a partir del cual se envía alerta (por defecto 80%)
NOTIF_DISK_THRESHOLD=80

# Segundos entre comprobaciones automáticas (por defecto 900 = 15 min)
NOTIF_CHECK_INTERVAL=900

# Segundos mínimos entre dos alertas del mismo tipo (por defecto 14400 = 4 h)
NOTIF_COOLDOWN=14400

# ── Integraciones externas (R-069 / Ruta 8.5) ────────────────────────────────
# URL webhook Jira Service Management (vacío = desactivado).
# Cuando se crea un ticket de soporte en el panel, se hace un POST a esta URL.
# Compatible con cualquier webhook que acepte JSON (Jira, GitHub Issues, etc.)
# Ejemplo Jira: https://tu-instancia.atlassian.net/rest/webhooks/1.0/webhook/<ID>
JIRA_WEBHOOK_URL=

# Segundos de timeout para el webhook Jira (por defecto 5)
JIRA_WEBHOOK_TIMEOUT=5

# ── Heartbeat a Central Support (R-080 / Ruta 10.4)
# Intervalo en segundos entre heartbeats (por defecto 300 = 5 minutos).
# Requiere que CENTRAL_SUPPORT_ENABLED=true y CENTRAL_SUPPORT_URL configurados.
# Valor 0 desactiva el heartbeat aunque el soporte central esté activo.
CENTRAL_HEARTBEAT_INTERVAL=300

# ── Vigex Agent — hosts Windows gestionados por agente HTTP (R-101) ──────────
# Puerto en que escucha el agente en cada servidor Windows (por defecto 8050).
VIGEX_AGENT_PORT=8050
# Mapa ip→token de hosts Windows. Formato: "ip1:token1,ip2:token2"
# Los hosts aquí listados usarán el agente HTTP en lugar de SSH.
# Dejar vacío si no hay servidores Windows gestionados.
VIGEX_AGENT_TOKEN_MAP=
