# Vigex para Windows — Docker config.env.example
#
# Copia este archivo como "config.env" en la carpeta de Vigex y edita los valores.
# NUNCA compartas este archivo con claves reales.
#
# Topología: este contenedor es el panel/API de Vigex.
# Los demás servicios (DB, backups) deben ser accesibles por SSH desde este host.
#
# Para el perfil "lite" (todo en un servidor Linux remoto accesible por SSH):
#   - SERVICIOS_HOST, BACKUPS_HOST, TERMINAL_DATABASE_HOST = IP del servidor Linux
#   - VIGEX_SSH_ALLOWED_HOSTS = IP del servidor Linux
#
# Para el perfil "single" (solo panel local, sin backups/DB remotos):
#   - Deja las IPs de servicios vacías
#   - VIGEX_SSH_ALLOWED_HOSTS = vacío

# ── Seguridad ──────────────────────────────────────────────────────────────────
SECRET_KEY=CAMBIAR_POR_CLAVE_ALEATORIA_LARGA
ADMIN_USER=admin
ADMIN_PASSWORD=CAMBIAR_PASSWORD_ADMIN

# ── Hosts remotos (SSH) ───────────────────────────────────────────────────────
SSH_USER=vigex
SERVICIOS_HOST=IP_SERVIDOR_LINUX
BACKUPS_HOST=IP_SERVIDOR_LINUX
TERMINAL_DATABASE_HOST=IP_SERVIDOR_LINUX

# ── Base de datos de logs (MariaDB remota) ────────────────────────────────────
LOGS_DB_HOST=IP_SERVIDOR_LINUX
LOGS_DB_NAME=vigex_logs
LOGS_DB_USER=vigex_logs
LOGS_DB_PASS=CAMBIAR_PASSWORD_LOGS
LOGS_ORIGIN=vigex-docker

# ── Rutas internas del contenedor (no cambiar salvo customización) ────────────
ALERTS_DB_PATH=data/alerts.db
CUMPLIMIENTO_DB_PATH=data/cumplimiento.db
CUMPLIMIENTO_ENABLED=true
CUMPLIMIENTO_COLLECT_INTERVAL=86400

BACKUP_OUTPUT_DIR=/var/backups/vigex/mysql/full
BACKUP_RETENTION_KEEP=10

# ── SSH endurecido (paths dentro del contenedor) ──────────────────────────────
VIGEX_SSH_KEY=/app/.ssh/id_rsa_vigex
VIGEX_SSH_KNOWN_HOSTS=/app/.ssh/known_hosts_vigex
VIGEX_SSH_TIMEOUT=30
VIGEX_SSH_CONNECT_TIMEOUT=10
VIGEX_SSH_STDIN_MAX_LENGTH=20000
VIGEX_SSH_ALLOWED_HOSTS=IP_SERVIDOR_LINUX
VIGEX_SSH_MULTIPLEX=true
VIGEX_SSH_CONTROL_PERSIST=30
VIGEX_SSH_CONTROL_DIR=/app/.ssh/cm

# ── Backup de base de datos ───────────────────────────────────────────────────
BACKUP_DB_HOST=IP_SERVIDOR_LINUX
BACKUP_DB_NAME=vigex_logs
BACKUP_DB_USER=vigex_backup
BACKUP_DB_PASS=CAMBIAR_PASSWORD_BACKUP

RESTORE_DB_HOST=IP_SERVIDOR_LINUX
RESTORE_DB_USER=vigex_restore
RESTORE_DB_PASS=CAMBIAR_PASSWORD_RESTORE
RESTORE_TARGET_DB=vigex_logs_restore_test

# ── Seguridad web ─────────────────────────────────────────────────────────────
VIGEX_CORS_ALLOWED_ORIGINS=
VIGEX_SESSION_HTTPS_ONLY=false
VIGEX_SESSION_MAX_AGE=28800
VIGEX_AUTO_LOGOUT_MINUTES=60
VIGEX_LOGIN_MAX_ATTEMPTS=5
VIGEX_LOGIN_WINDOW_SECONDS=900

# ── Alertas Telegram (R-098) ──────────────────────────────────────────────────
# "central" usa @VigexPanelBot (recomendado). Solo necesitas tu TELEGRAM_CHAT_ID.
# Para obtenerlo: escribe /chatid al bot @VigexPanelBot en Telegram.
VIGEX_TELEGRAM_MODE=central
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ── Asistente IA (R-090 / R-097) ──────────────────────────────────────────────
VIGEX_RAG_ENABLED=true
# "central" = usa Vigex Central como proxy LLM (recomendado, sin API key propia)
VIGEX_RAG_LLM_PROVIDER=central
VIGEX_RAG_OLLAMA_URL=http://localhost:11434
VIGEX_RAG_OLLAMA_MODEL=mistral
ANTHROPIC_API_KEY=
VIGEX_RAG_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GOOGLE_API_KEY=
VIGEX_RAG_GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
VIGEX_RAG_OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
VIGEX_RAG_GROQ_MODEL=llama-3.3-70b-versatile
VIGEX_RAG_TOP_K=5
VIGEX_RAG_MAX_TOKENS=700
VIGEX_RAG_RATE_LIMIT_REQS=30
VIGEX_RAG_RATE_LIMIT_WINDOW=60

# ── Vigex Central (soporte + LLM proxy) ───────────────────────────────────────
# Configura esto si tienes una instancia de Vigex Central (R-097).
CENTRAL_SUPPORT_ENABLED=false
CENTRAL_SUPPORT_URL=https://tu-central.vigex.es
CENTRAL_SUPPORT_CLIENT_ID=cliente-demo
CENTRAL_SUPPORT_TOKEN=CAMBIAR_TOKEN_CLIENTE
CENTRAL_HEARTBEAT_INTERVAL=300

# ── Notificaciones proactivas ─────────────────────────────────────────────────
NOTIF_ENABLED=false
NOTIF_EMAIL_TO=admin@tuempresa.com
NOTIF_EMAIL_FROM=vigex@tuempresa.com
NOTIF_SMTP_HOST=smtp.gmail.com
NOTIF_SMTP_PORT=587
NOTIF_SMTP_USER=vigex@tuempresa.com
NOTIF_SMTP_PASS=CONTRASEÑA_DE_APLICACION
NOTIF_DISK_THRESHOLD=80
NOTIF_CHECK_INTERVAL=900
NOTIF_COOLDOWN=14400

# ── Webhook Jira (opcional) ───────────────────────────────────────────────────
JIRA_WEBHOOK_URL=
JIRA_WEBHOOK_TIMEOUT=5

CACTI_URL=/cacti/
ALERTS_DEFAULT_CHANNEL=telegram
