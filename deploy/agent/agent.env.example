# Vigex Agent — configuracion
# Copia como agent.env y edita los valores.

# Token de autenticacion (generado por el instalador — cambiar en produccion)
VIGEX_AGENT_TOKEN=CAMBIAR_POR_TOKEN_ALEATORIO_64_CHARS

# Puerto de escucha del agente
VIGEX_AGENT_PORT=8050

# ── Base de datos ──────────────────────────────────────────────────────────────
# "auto" detecta el motor instalado (MySQL/MariaDB o SQL Server)
# Forzar con "mysql" o "sqlserver" si la deteccion falla
VIGEX_DB_BACKEND=auto
VIGEX_DB_HOST=localhost
# 0 = puerto por defecto del motor (3306 MySQL, 1433 SQL Server)
VIGEX_DB_PORT=0
VIGEX_DB_USER=vigex_backup
VIGEX_DB_PASS=CAMBIAR_PASSWORD_BACKUP

# ── Backups ────────────────────────────────────────────────────────────────────
VIGEX_BACKUP_DIR=C:\Vigex\backups
VIGEX_BACKUP_RETENTION=10

# ── Servicios monitorizados ────────────────────────────────────────────────────
# Nombres exactos de servicios Windows (separados por coma)
# Ejemplo: MySQL80,W3SVC,Spooler,MSSQLSERVER
VIGEX_MONITORED_SERVICES=
