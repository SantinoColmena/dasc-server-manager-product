SECRET_KEY=CAMBIAR_SECRET_KEY_SEGURA
ADMIN_USER=admin
ADMIN_PASSWORD=CAMBIAR_PASSWORD_ADMIN

SSH_USER=vigex
SERVICIOS_HOST=192.168.60.30
BACKUPS_HOST=192.168.60.30
TERMINAL_DATABASE_HOST=192.168.60.20

CACTI_URL=/cacti/

LOGS_DB_HOST=192.168.60.20
LOGS_DB_NAME=vigex_logs
LOGS_DB_USER=vigex_logs
LOGS_DB_PASS=vigex_logs_2026
LOGS_ORIGIN=vigex-web

ALERTS_DB_PATH=data/alerts.db
ALERTS_DEFAULT_CHANNEL=telegram

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHAT_ID=

# SSH endurecido Vigex
VIGEX_SSH_KEY=/opt/vigex/api/.ssh/id_rsa_vigex
VIGEX_SSH_KNOWN_HOSTS=/opt/vigex/api/.ssh/known_hosts_vigex
VIGEX_SSH_TIMEOUT=30
VIGEX_SSH_CONNECT_TIMEOUT=10
VIGEX_SSH_STDIN_MAX_LENGTH=20000
VIGEX_SSH_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.60.20,192.168.60.30,192.168.60.40