# ============================================
# Vigex - Perfil DISTRIBUTED / Pro
# Instalación completa en varios servidores
# Panel/API + Base de datos + Backups/servicios/logs
# ============================================

# Perfil de instalación
INSTALL_MODE=distributed
VIGEX_PROFILE_NAME=Vigex Pro
VIGEX_PROFILE_DESCRIPTION=Panel/API, base de datos y backups separados en servidores distintos

# Usuario SSH
SSH_USER=vigex

# Hosts
# Ejemplo:
# - API / Panel: servidor actual
# - DB / Logs: 192.168.60.20
# - Backups / Servicios: 192.168.60.30
SERVICIOS_HOST=192.168.60.30
BACKUPS_HOST=192.168.60.30
LOGS_DB_HOST=192.168.60.20
DB_HOST=192.168.60.20

# Base de datos principal
DB_NAME=employees
DB_BACKUP_USER=vigex_backup
DB_BACKUP_PASS=cambiar_password_backup

# Logs
LOGS_DB_NAME=vigex_logs
LOGS_DB_USER=vigex_logs
LOGS_DB_PASS=cambiar_password_logs
LOGS_ORIGIN=vigex-web

# Panel
SECRET_KEY=cambiar_clave_secreta
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar_password_admin

# Cacti / monitorización
CACTI_URL=/cacti/

# Copia externa opcional pero recomendable
EXTERNAL_BACKUP_REQUIRED=recommended
EXTERNAL_BACKUP_ENABLED=no
EXTERNAL_BACKUP_TYPE=none
EXTERNAL_BACKUP_PATH=/mnt/vigex-external

# SFTP/NAS futuro
EXTERNAL_SFTP_HOST=
EXTERNAL_SFTP_PORT=22
EXTERNAL_SFTP_USER=
EXTERNAL_SFTP_REMOTE_PATH=

# Cifrado futuro
EXTERNAL_BACKUP_ENCRYPTION=none
EXTERNAL_SYNC_DELETE=no
EXTERNAL_GPG_PASSPHRASE=

# ── Vigex Agent — servidores Windows gestionados (R-101/R-102) ───────────────
# Puerto en que escucha el agente en cada servidor Windows (por defecto 8050).
VIGEX_AGENT_PORT=8050
# Hosts Windows a gestionar. Formato: "ip1:token1,ip2:token2"
# En perfil Distributed: cualquier combinación de los hosts puede ser Windows.
# Añade aquí los que tengan VigexAgent.exe instalado; el resto usará SSH.
# Ejemplo: VIGEX_AGENT_TOKEN_MAP=192.168.60.20:token1,192.168.60.30:token2
VIGEX_AGENT_TOKEN_MAP=
